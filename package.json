{
  "name": "use-user-location",
  "type": "module",
  "version": "1.0.0",
  "description": "A React hook for getting the user's location with address lookup and fallbacks.",
  "main": "./dist/use-user-location.cjs",
  "module": "./dist/use-user-location.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/use-user-location.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/use-user-location.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "unpkg": "./dist/use-user-location.umd.js",
  "jsdelivr": "./dist/use-user-location.umd.js",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build && node scripts/postbuild.mjs",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "prepare": "husky",
    "cs:add": "pnpm changeset add",
    "cs:version": "pnpm changeset version",
    "cs:publish": "pnpm run ci && pnpm changeset publish",
    "commitlint": "commitlint --edit",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "react",
    "hook",
    "location",
    "geolocation",
    "geocoding",
    "address",
    "coordinates"
  ],
  "author": "maximsan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maximsan/use-user-location.git"
  },
  "bugs": {
    "url": "https://github.com/maximsan/use-user-location/issues"
  },
  "homepage": "https://github.com/maximsan/use-user-location#readme",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.8.0",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  }
}
