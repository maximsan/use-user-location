{
  "name": "use-user-location",
  "version": "0.1.0",
  "description": "A React hook for getting the user's location with address lookup and fallbacks.",
  "main": "dist/use-user-location.umd.js",
  "module": "dist/use-user-location.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "prepare": "husky",
    "cs:add": "pnpm changeset add",
    "cs:version": "pnpm changeset version",
    "cs:publish": "pnpm run typecheck && pnpm run build && pnpm changeset publish",
    "commitlint": "commitlint --edit"
  },
  "keywords": [
    "react",
    "hook",
    "location",
    "geolocation",
    "geocoding",
    "address",
    "coordinates"
  ],
  "author": "maximsan",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.0.0",
    "husky": "^8.0.0",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1"
  }
}
